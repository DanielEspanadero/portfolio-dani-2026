function getIcon(name: string): string {
  return icons[name] ?? '';
}
---

<section id="especializacion" class="section container" aria-labelledby="expertise-title">
  <p class="eyebrow">Especialización</p>
  <h2 id="expertise-title" class="section-title">Menos ruido, más foco técnico.</h2>
  <p class="section-description">
    El portfolio prioriza las áreas donde el perfil aporta más valor: backend Java/Spring, arquitectura, seguridad e IA aplicada.
  </p>
  <div class="grid">
    <article class="surface card">
      <h3>Tecnologías principales</h3>
      <p>Stack curado para backend Java/Spring y soporte enterprise.</p>
      <ul class="tech-list">
        {technologies.map((tech) => (
          <li class="tech-pill" title={tech.category}>
            <span class="tech-icon" set:html={getIcon(tech.name)} />
            <span class="tech-name">{tech.name}</span>
          </li>
        ))}
      </ul>
    </article>
    {technicalPractices.map((group) => (
      <article class="surface card">
        <h3>{group.title}</h3>
        <p>{group.description}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .section {
    padding-block: 5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .card {
    padding: 1.4rem;
  }

  h3 {
    margin: 0;
    font-size: 1.35rem;
  }

  p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0;
    margin: 1.25rem 0 0;
    list-style: none;
  }

  .tech-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    font-size: 0.875rem;
    color: var(--color-text);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .tech-pill:hover {
    background: rgba(52, 211, 153, 0.1);
    border-color: var(--color-primary);
  }

  .tech-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.15rem;
    height: 1.15rem;
    flex-shrink: 0;
  }

  .tech-icon :global(svg) {
    width: 100%;
    height: 100%;
    fill: var(--color-primary);
  }

  .tech-name {
    line-height: 1;
  }

  @media (max-width: 760px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
