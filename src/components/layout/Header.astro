---
import { profile } from '@data/profile';
---

<header class="site-header">
  <nav class="container nav" aria-label="Navegación principal">
    <a class="brand" href="/" aria-label="Inicio - Daniel Españadero">
      <span class="brand-mark">DE</span>
      <span>{profile.name}</span>
    </a>
    <div class="nav-links">
      <a href="/#perfil">Perfil</a>
      <a href="/#stack">Stack</a>
      <a href="/#experiencia">Experiencia</a>
      <a href="/#autoridad">Autoridad</a>
      <a class="contact-link" href="/#contacto">Contacto</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 20;
    top: 0;
    border-bottom: 1px solid var(--color-border);
    background: rgba(7, 11, 18, 0.78);
    backdrop-filter: blur(18px);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 72px;
  }

  .brand,
  .nav-links {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 0.75rem;
    font-weight: 700;
  }

  .brand-mark {
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    color: #06101a;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .nav-links {
    gap: 1rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .contact-link {
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: #06101a;
    background: var(--color-primary);
    font-weight: 800;
  }

  @media (max-width: 840px) {
    .nav {
      align-items: flex-start;
      flex-direction: column;
      padding-block: 1rem;
    }

    .nav-links {
      overflow-x: auto;
      width: 100%;
      padding-bottom: 0.25rem;
    }
  }
</style>
