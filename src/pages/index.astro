---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Contact from '@components/home/Contact.astro';
import Button from '@components/ui/Button.astro';
import { profile } from '@data/profile';
import { technicalPractices, technologies } from '@data/skills';

const techIcons: Record<string, string> = {
  'Java':            '/icons/tech/java.svg',
  'Spring Boot':     '/icons/tech/spring-boot.svg',
  'Spring Security': '/icons/tech/spring-security.svg',
  'MySQL':           '/icons/tech/mysql.svg',
  'Docker':          '/icons/tech/docker.svg',
  'AWS':             '/icons/tech/aws.svg',
  'Linux':           '/icons/tech/linux.svg',
  'Angular':         '/icons/tech/angular.svg',
  'SQL':             '/icons/tech/mysql.svg',
  'MongoDB':         '/icons/tech/mongodb.svg',
  'React':           '/icons/tech/react.svg',
  'Node.js':         '/icons/tech/nodejs.svg',
  'Express':         '/icons/tech/express.svg',
};

const companyLogos: Record<string, string> = {
  'Optimissa':    '/icons/companies/optimissa.png',
  'Mytic Innova': '/icons/companies/mytic.png',
  'Malt':         '/icons/companies/malt.svg',
};

const techColors: Record<string, string> = {
  'Java': '#f89820',
  'Spring Boot': '#6db33f',
  'Spring Security': '#5ba033',
  'MySQL': '#1a9ae0',
  'Docker': '#2496ed',
  'AWS': '#ff9900',
  'Linux': '#fcc624',
  'Angular': '#dd0031',
};
import { experiences } from '@data/experience';

const title = 'Daniel Españadero | Software Engineer Java, Spring Boot e IA';
const description = 'Portfolio profesional de Daniel Españadero, Software Engineer especializado en backend, Java, Spring Boot, arquitectura limpia e IA aplicada.';

const youtubeStats = [
  { value: '+24k', label: 'desarrolladores en la comunidad' },
  { value: '+500', label: 'vídeos publicados' },
  { value: '+4M', label: 'visualizaciones acumuladas' },
];

const youtubePillars = [
  'Java y Spring Boot',
  'Arquitectura hexagonal',
  'Spring Security',
  'IA aplicada',
  'Carrera técnica',
];

const featuredVideos = [
  {
    title: 'Arquitectura Hexagonal con Java y Spring',
    description: 'Una explicación larga, práctica y con proyecto sobre cómo separar dominio, aplicación e infraestructura sin caer en teoría vacía.',
    meta: '+82k visualizaciones',
    href: 'https://www.youtube.com/watch?v=JD_ZL3Bnaog',
  },
  {
    title: 'API REST con Java, Spring Boot y MySQL',
    description: 'Backend completo, CRUD real y persistencia: contenido técnico alineado con el tipo de sistemas que construyo profesionalmente.',
    meta: '+89k visualizaciones',
    href: 'https://www.youtube.com/watch?v=M7lhQMzzHWU',
  },
  {
    title: 'Spring Security de 0 a proyecto completo',
    description: 'Seguridad aplicada a backend Java explicada paso a paso, desde los conceptos hasta una implementación usable.',
    meta: '+17k visualizaciones',
    href: 'https://www.youtube.com/watch?v=Qu3soRF168I',
  },
  {
    title: 'Concurrencia en Java con proyecto completo',
    description: 'Threads, sincronización y ejecución concurrente explicados desde la práctica para entender cómo se comporta Java en escenarios reales.',
    meta: '+13k visualizaciones',
    href: 'https://www.youtube.com/watch?v=cskoNJCWMws',
  },
  {
    title: 'Spring Boot + MySQL desplegado en AWS',
    description: 'Despliegue completo usando EC2 y RDS para llevar una aplicación backend Java desde local hasta infraestructura cloud.',
    meta: '+16k visualizaciones',
    href: 'https://www.youtube.com/watch?v=gEWqXYlC4ak',
  },
  {
    title: 'AWS S3 con Java: CRUD completo',
    description: 'Subida, descarga, modificación y borrado de archivos con Java y S3, conectando backend con servicios cloud de forma práctica.',
    meta: '+9k visualizaciones',
    href: 'https://www.youtube.com/watch?v=b186cnroYyc',
  },
];

const bookStats = [
  { value: '4.5/5', label: 'valoración media en Amazon', icon: 'star', rating: 4.5 },
  { value: '26', label: 'reseñas de lectores', icon: 'readers' },
  { value: '140', label: 'páginas en español', icon: 'pages' },
];

function starType(pos: number, rating: number): 'full' | 'half' | 'empty' {
  if (rating >= pos) return 'full';
  if (rating >= pos - 0.5) return 'half';
  return 'empty';
}

const bookHighlights = [
  'Elegir un camino realista para aprender programación.',
  'Construir proyectos, GitHub, LinkedIn y portfolio con intención.',
  'Preparar entrevistas y dar los primeros pasos en el primer empleo.',
];
---

<BaseLayout {title} {description}>
  <section class="hero container" aria-labelledby="hero-title">
    <div class="hero-statement">
      <p class="eyebrow">Backend · Java · Spring Boot · IA aplicada</p>
      <h1 id="hero-title" class="hero-title" aria-label="Software Engineer">
        <span class="hero-title-line">SOFTWARE</span>
        <span class="hero-title-line">ENGINEER</span>
      </h1>
      <div class="hero-actions">
        <Button href="#contacto">Contactar</Button>
        <Button href="#perfil" variant="secondary">Conocer mi perfil</Button>
      </div>
    </div>

    <aside class="hero-profile surface" aria-label="Perfil de Daniel Españadero">
      <div class="hero-photo-frame">
        <img src="/images/dani.png" alt="Retrato profesional de Daniel Españadero" width="420" height="520" loading="eager" decoding="async" />
      </div>
      <div class="hero-profile-content">
        <div class="hero-profile-heading">
          <p class="hero-profile-label">Perfil</p>
          <span class="hero-status">Backend</span>
        </div>
        <h2>Daniel Españadero</h2>
        <p class="hero-role">Backend Software Engineer</p>
        <ul aria-label="Tecnologías principales">
          <li>Java</li>
          <li>Spring Boot</li>
          <li>Spring Security</li>
          <li>Arquitectura backend</li>
          <li>IA aplicada</li>
        </ul>
        <p class="hero-profile-note">Autor de un libro de programación y creador de contenido técnico.</p>
      </div>
    </aside>
  </section>

  <section id="perfil" class="profile-section container" aria-labelledby="profile-title">
    <div class="profile-shell surface">
      <div class="profile-copy">
        <p class="eyebrow">Perfil</p>
        <h2 id="profile-title" class="section-title">Backend engineer con criterio de arquitectura, producto y comunicación técnica.</h2>
        <p>
          Soy Daniel Españadero, Backend Software Engineer especializado en Java, Spring Boot, arquitectura backend e IA aplicada. Construyo software mantenible para sistemas reales, no demos bonitas.
        </p>
      </div>

      <blockquote class="profile-manifesto">
        <p>Construir backend no va de acumular frameworks. Va de tomar buenas decisiones bajo restricciones reales.</p>
      </blockquote>

      <div class="profile-proof" aria-label="Pruebas profesionales de Daniel Españadero">
        <article class="reveal-item" style="--i: 0">
          <span>01</span>
          <h3>Ingeniería backend</h3>
          <p>Java, Spring Boot, Spring Security, APIs REST y sistemas mantenibles.</p>
        </article>
        <article class="reveal-item" style="--i: 1">
          <span>02</span>
          <h3>Arquitectura aplicada</h3>
          <p>Hexagonal Architecture, testing, diseño de APIs y evolución de software.</p>
        </article>
        <article class="reveal-item" style="--i: 2">
          <span>03</span>
          <h3>Autoridad técnica</h3>
          <p>Autor de un libro de programación y creador de contenido técnico para más de <strong>24.000 desarrolladores en YouTube</strong>.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="stack" class="stack-section container" aria-labelledby="stack-title">
    <p class="eyebrow">Stack y criterio técnico</p>
    <div class="stack-heading-row">
      <h2 id="stack-title" class="section-title">Herramientas visibles. Criterio invisible. Las dos cosas importan.</h2>
      <p>
        Separar tecnologías de habilidades no es estético: es arquitectura de comunicación. Una cosa es con qué construyo; otra, cómo tomo decisiones.
      </p>
    </div>

    <div class="technology-panel surface" aria-labelledby="technologies-title">
      <div class="stack-subheading">
        <span>01</span>
        <h3 id="technologies-title">Tecnologías principales</h3>
        <p>Stack curado para backend Java/Spring, soporte enterprise y entrega de software real.</p>
      </div>
      <div class="technology-grid">
        {technologies.map((technology, index) => (
          <article class="technology-card" style={`--tc: ${techColors[technology.name] ?? '#34d399'}; --i: ${index}`}>
            <img src={technology.icon} alt="" width="64" height="64" loading="lazy" decoding="async" />
            <strong>{technology.name}</strong>
            <span>{technology.category}</span>
          </article>
        ))}
      </div>
    </div>

    <div class="practice-panel" aria-labelledby="practices-title">
      <div class="stack-subheading">
        <span>02</span>
        <h3 id="practices-title">Habilidades técnicas</h3>
        <p>La parte que no cabe en un logo: arquitectura, calidad, integración y criterio para mantener sistemas vivos.</p>
      </div>
      <div class="practice-grid">
        {technicalPractices.map((practice, index) => (
          <article class="practice-card surface reveal-item" style={`--i: ${index}`}>
            <span>0{index + 1}</span>
            <h4>{practice.title}</h4>
            <p>{practice.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="experiencia" class="experience-section container" aria-labelledby="experience-title">
    <div class="section-heading-row">
      <div>
        <p class="eyebrow">Experiencia</p>
        <h2 id="experience-title" class="section-title">Software en entornos reales, no solo demos bonitas.</h2>
      </div>
      <p>
        Experiencia profesional orientada a desarrollo backend, integración de sistemas y construcción de soluciones mantenibles en contexto empresarial.
      </p>
    </div>
    <div class="experience-list">
      {experiences.map((experience, index) => {
        const logo = companyLogos[experience.company];
        return (
          <article class="experience-item reveal-item" style={`--i: ${index}`}>
            <div class="experience-left">
              {logo && (
                <div class="company-logo-wrap">
                  <img src={logo} alt={experience.company} class="company-logo" width="160" height="48" loading="lazy" decoding="async" />
                </div>
              )}
              <span class="experience-period">{experience.period}</span>
              <p class="experience-role">{experience.role}</p>
              <div class="experience-stack">
                {experience.stack.map((s) => (
                  <span class="stack-pill">
                    {techIcons[s] && (
                      <img src={techIcons[s]} alt="" width="14" height="14" aria-hidden="true" />
                    )}
                    {s}
                  </span>
                ))}
              </div>
            </div>
            <div class="experience-right">
              <p>{experience.description}</p>
              <ul>
                {experience.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section id="youtube" class="youtube-section container" aria-labelledby="youtube-title">
    <div class="youtube-shell surface">
      <div class="youtube-hero">
        <div class="youtube-copy">
          <p class="eyebrow">Creador de contenido técnico</p>
          <h2 id="youtube-title" class="section-title">Enseñar backend también es parte de mi ingeniería.</h2>
          <p>
            En mi canal comparto Java, Spring Boot, arquitectura backend, fundamentos de software e IA aplicada con una comunidad de más de <strong>24.000 desarrolladores</strong>. No es contenido decorativo: es una forma de ordenar ideas, bajar conceptos complejos a tierra y construir criterio técnico en público.
          </p>
          <div class="youtube-actions">
            <Button href={profile.links.youtube} target="_blank" rel="noreferrer">Ver canal</Button>
          </div>
        </div>

        <aside class="youtube-proof" aria-label="Datos del canal de YouTube de Daniel Españadero">
          <div class="youtube-logo" aria-hidden="true">
            <svg viewBox="0 0 28 20" role="img" focusable="false">
              <path d="M27.42 3.12A3.5 3.5 0 0 0 24.96.64C22.78.05 14 .05 14 .05S5.22.05 3.04.64A3.5 3.5 0 0 0 .58 3.12C0 5.32 0 9.9 0 9.9s0 4.58.58 6.78a3.5 3.5 0 0 0 2.46 2.48c2.18.59 10.96.59 10.96.59s8.78 0 10.96-.59a3.5 3.5 0 0 0 2.46-2.48C28 14.48 28 9.9 28 9.9s0-4.58-.58-6.78Z" />
              <path d="M11.2 14.1V5.7l7.28 4.2-7.28 4.2Z" />
            </svg>
          </div>
          <p class="youtube-proof-label">Daniel Españadero en YouTube</p>
          <div class="youtube-stat-grid">
            {youtubeStats.map((stat) => (
              <article>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </article>
            ))}
          </div>
        </aside>
      </div>

      <div class="youtube-pillar-row" aria-label="Temas principales del canal">
        {youtubePillars.map((pillar) => <span>{pillar}</span>)}
      </div>

      <div class="featured-video-grid" aria-label="Vídeos destacados del canal">
        {featuredVideos.map((video, index) => (
          <article class="featured-video-card reveal-item" style={`--i: ${index}`}>
            <span>0{index + 1}</span>
            <p>{video.meta}</p>
            <h3>{video.title}</h3>
            <p>{video.description}</p>
            <a href={video.href} target="_blank" rel="noreferrer">Ver vídeo</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="libro" class="book-section container" aria-labelledby="book-title">
    <div class="book-shell surface">
      <div class="book-visual" aria-label="Portada del libro Guía para aprender a programar">
        <img
          class="book-cover"
          src="/images/guia-para-aprender-a-programar.png"
          alt="Portada del libro Guía para aprender a programar: Desde Cero Hasta tu Primer Empleo, de Daniel Españadero Fernández"
          width="1294"
          height="2000"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="book-copy">
        <p class="eyebrow">Autor técnico</p>
        <h2 id="book-title" class="section-title">Un libro para convertir el aprendizaje en dirección.</h2>
        <p>
          <strong>“Guía para aprender a programar: Desde Cero Hasta tu Primer Empleo”</strong> condensa una parte clave de mi trabajo como divulgador: ayudar a personas que empiezan a ordenar el caos, elegir un camino y construir un perfil profesional con criterio.
        </p>
        <p>
          No es un libro sobre memorizar sintaxis. Es una guía práctica sobre mentalidad, proyectos, marca personal, entrevistas y primeros pasos para entrar en programación sin vender atajos mágicos.
        </p>

        <div class="book-stat-grid" aria-label="Datos del libro en Amazon">
          {bookStats.map((stat, index) => (
            <article class:list={['reveal-item', { 'stat-book': stat.icon === 'pages' }]} style={`--i: ${index}`}>
              <span>{stat.label}</span>
              <strong>
                {stat.value}
                {stat.icon === 'readers' && (
                  <svg width="0.75em" height="0.75em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="stat-icon">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                )}
                {stat.icon === 'pages' && (
                  <svg width="0.75em" height="0.75em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="stat-icon">
                    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                  </svg>
                )}
              </strong>
              <div class="star-row" role={stat.icon === 'star' ? 'img' : undefined} aria-label={stat.icon === 'star' ? `${stat.rating} de 5 estrellas` : undefined} aria-hidden={stat.icon !== 'star' ? 'true' : undefined}>
                {stat.icon === 'star' && [1,2,3,4,5].map((pos) => {
                  const type = starType(pos, stat.rating ?? 0);
                  const p = 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z';
                  return (
                    <svg width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true">
                      {type === 'half' && (
                        <defs>
                          <clipPath id="star-left">
                            <rect x="0" y="0" width="12" height="24"/>
                          </clipPath>
                        </defs>
                      )}
                      {type === 'full' && <path fill="currentColor" d={p}/>}
                      {type === 'half' && <path fill="currentColor" clip-path="url(#star-left)" d={p}/>}
                      {type !== 'full' && <path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" d={p}/>}
                    </svg>
                  );
                })}
              </div>
            </article>
          ))}
        </div>

        <ul class="book-highlight-list" aria-label="Temas principales del libro">
          {bookHighlights.map((highlight, index) => <li class="reveal-item" style={`--i: ${index}`}>{highlight}</li>)}
        </ul>

        <div class="book-actions">
          <Button href={profile.links.book} target="_blank" rel="noreferrer">Ver libro en Amazon</Button>
        </div>
      </div>
    </div>
  </section>

  <Contact />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { rootMargin: '0px 0px -40px 0px', threshold: 0.08 }
  );
  document.querySelectorAll('.technology-card, .reveal-item').forEach((el) => observer.observe(el));
</script>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    display: grid;
    grid-template-columns: minmax(0, 1.28fr) minmax(300px, 0.72fr);
    gap: clamp(2.5rem, 5vw, 4.25rem);
    align-items: center;
    min-height: calc(86svh - 72px);
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
  }

  .hero::before,
  .hero::after {
    position: absolute;
    z-index: -1;
    pointer-events: none;
    content: '';
  }

  .hero::before {
    inset: 6% 38% 12% -18%;
    background: radial-gradient(circle at 42% 52%, rgba(52, 211, 153, 0.18), transparent 58%);
    filter: blur(12px);
  }

  .hero::after {
    inset: 14% 42% 18% -8%;
    background-image: radial-gradient(circle, rgba(52, 211, 153, 0.15) 1px, transparent 1.4px);
    background-size: 28px 28px;
    mask-image: linear-gradient(90deg, transparent, black 18%, black 62%, transparent),
      linear-gradient(180deg, transparent, black 16%, black 78%, transparent);
    mask-composite: intersect;
    opacity: 0.48;
  }

  .hero-statement,
  .hero-profile {
    position: relative;
    z-index: 1;
  }

  .hero-statement {
    min-width: 0;
  }

  .hero-title {
    display: grid;
    gap: 0.03em;
    margin: 0;
    font-size: clamp(4rem, 7.8vw, 7.25rem);
    line-height: 0.88;
    letter-spacing: -0.025em;
    text-transform: uppercase;
    overflow-wrap: normal;
    word-break: keep-all;
    user-select: none;
  }

  .hero-statement .eyebrow {
    user-select: none;
  }

  .hero-title-line {
    display: block;
    white-space: nowrap;
  }

  .hero-profile {
    overflow: hidden;
    box-shadow:
      0 28px 90px rgba(0, 0, 0, 0.34),
      0 0 70px rgba(52, 211, 153, 0.08),
      0 0 90px rgba(167, 243, 208, 0.05);
    background:
      radial-gradient(circle at 18% 16%, rgba(52, 211, 153, 0.2), transparent 14rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent 42%),
      rgba(13, 19, 34, 0.9);
    animation: profile-glow 5s ease-in-out infinite;
  }

  @keyframes profile-glow {
    0%, 100% {
      box-shadow:
        0 28px 90px rgba(0, 0, 0, 0.34),
        0 0 70px rgba(52, 211, 153, 0.08),
        0 0 90px rgba(167, 243, 208, 0.05);
    }
    50% {
      box-shadow:
        0 28px 90px rgba(0, 0, 0, 0.34),
        0 0 90px rgba(52, 211, 153, 0.22),
        0 0 130px rgba(167, 243, 208, 0.13);
    }
  }

  .hero-photo-frame {
    margin: clamp(0.85rem, 2vw, 1rem) clamp(0.85rem, 2vw, 1rem) 0;
    height: clamp(17rem, 38svh, 25.5rem);
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius-lg) - 0.5rem);
    background: rgba(255, 255, 255, 0.035);
  }

  .hero-photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero-profile-content {
    display: grid;
    gap: 0.8rem;
    padding: clamp(1.25rem, 3vw, 1.8rem);
  }

  .hero-profile-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-profile-label {
    margin: 0;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.6rem;
    border: 1px solid rgba(167, 243, 208, 0.24);
    border-radius: 999px;
    color: var(--color-accent);
    background: rgba(167, 243, 208, 0.08);
    font-size: 0.75rem;
    font-weight: 800;
  }

  .hero-status::before {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: currentColor;
    content: '';
    animation: status-pulse 2.4s ease-in-out infinite;
  }

  @keyframes status-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  .hero-profile h2 {
    margin: 0;
    font-size: clamp(2.15rem, 4vw, 3.25rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
  }

  .hero-role {
    margin: 0;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-profile ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .hero-profile li {
    padding: 0.45rem 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.035);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .hero-profile-note {
    margin: 0.25rem 0 0;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .section-heading-row > p {
    color: var(--color-text-muted);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .profile-section,
  .stack-section,
  .experience-section,
  .youtube-section,
  .book-section {
    padding-block: var(--section-space);
  }

  .profile-section {
    position: relative;
  }

  .profile-shell {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    overflow: hidden;
    padding: clamp(1.35rem, 4vw, 3.25rem);
    background:
      radial-gradient(circle at 78% 18%, rgba(52, 211, 153, 0.2), transparent 18rem),
      linear-gradient(135deg, rgba(255, 255, 255, 0.055), transparent 28%),
      linear-gradient(145deg, rgba(16, 24, 39, 0.94), rgba(8, 13, 22, 0.82));
  }

  .profile-shell::before,
  .profile-shell::after {
    position: absolute;
    pointer-events: none;
    content: '';
  }

  .profile-shell::before {
    inset: 0;
    background-image: radial-gradient(circle, rgba(167, 243, 208, 0.12) 1px, transparent 1.4px);
    background-size: 26px 26px;
    mask-image: linear-gradient(120deg, transparent, black 22%, transparent 74%);
    opacity: 0.38;
  }

  .profile-shell::after {
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    width: min(42%, 420px);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(167, 243, 208, 0.42), transparent);
    box-shadow:
      -72px -82px 0 rgba(167, 243, 208, 0.1),
      -24px -42px 0 rgba(167, 243, 208, 0.16),
      -120px -18px 0 rgba(167, 243, 208, 0.08);
  }

  .profile-copy,
  .profile-manifesto,
  .profile-proof {
    position: relative;
    z-index: 1;
  }

  .profile-copy p:not(.eyebrow) {
    max-width: 620px;
    color: var(--color-text-muted);
    font-size: clamp(1.02rem, 2vw, 1.18rem);
    line-height: 1.75;
  }

  .profile-manifesto {
    align-self: end;
    margin: 0;
    padding-left: clamp(1rem, 3vw, 2rem);
    border-left: 1px solid rgba(167, 243, 208, 0.28);
  }

  .profile-manifesto p {
    margin: 0;
    color: var(--color-text);
    font-size: clamp(1.8rem, 4vw, 3.45rem);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .profile-proof {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    grid-column: 1 / -1;
    overflow: hidden;
    margin-top: clamp(0.5rem, 2vw, 1rem);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius-lg) - 0.25rem);
    background:
      linear-gradient(90deg, rgba(52, 211, 153, 0.22), transparent 24%, transparent 76%, rgba(167, 243, 208, 0.12)),
      var(--color-border);
  }

  .profile-proof article {
    min-height: 230px;
    padding: clamp(1.1rem, 2.5vw, 1.55rem);
    background: rgba(5, 7, 13, 0.58);
  }

  .profile-proof span {
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .profile-proof h3 {
    margin: clamp(2rem, 5vw, 3.6rem) 0 0.75rem;
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
  }

  .profile-proof p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.98rem;
    line-height: 1.65;
  }


  .profile-proof strong {
    color: var(--color-text);
  }

  .stack-heading-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.58fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: end;
  }

  .stack-heading-row > p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .technology-panel {
    position: relative;
    overflow: hidden;
    margin-top: clamp(2rem, 5vw, 3rem);
    padding: clamp(1.25rem, 3vw, 2rem);
    background:
      radial-gradient(circle at 8% 12%, rgba(52, 211, 153, 0.18), transparent 16rem),
      linear-gradient(145deg, rgba(16, 24, 39, 0.94), rgba(8, 13, 22, 0.84));
  }

  .technology-panel::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: '';
    background-image:
      linear-gradient(rgba(167, 243, 208, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(167, 243, 208, 0.06) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: linear-gradient(90deg, black, transparent 78%);
  }

  .stack-subheading,
  .technology-grid,
  .practice-grid {
    position: relative;
    z-index: 1;
  }

  .stack-subheading {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.35rem 1rem;
    max-width: 760px;
  }

  .stack-subheading span {
    grid-row: span 2;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .stack-subheading h3 {
    margin: 0;
    font-size: clamp(1.55rem, 3vw, 2.25rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .stack-subheading p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .technology-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    margin-top: clamp(1.5rem, 4vw, 2rem);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius-lg) - 0.25rem);
    background: var(--color-border);
  }

  .technology-card {
    --tc: #34d399;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: clamp(1rem, 2.5vw, 1.5rem);
    min-height: 160px;
    background: rgba(5, 7, 13, 0.58);
    cursor: pointer;
    opacity: 0;
    transform: translateY(14px);
    transition: background 0.3s ease;
  }

  .technology-card.is-visible {
    animation: card-reveal 0.45s ease forwards;
    animation-delay: calc(var(--i, 0) * 55ms);
  }

  .technology-card:hover {
    background: color-mix(in srgb, var(--tc) 18%, rgba(5, 7, 13, 0.92));
  }

  .technology-card:hover::before {
    opacity: 1;
  }

  .technology-card:hover img {
    filter: drop-shadow(0 0 8px var(--tc)) brightness(1.15);
  }

  .technology-card:hover strong {
    color: color-mix(in srgb, var(--tc) 80%, var(--color-text));
  }

  .technology-card img {
    width: 3rem;
    height: 3rem;
    transition: filter 0.3s ease;
  }

  .technology-card::before {
    position: absolute;
    inset: auto auto -1px -1px;
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, color-mix(in srgb, var(--tc) 70%, transparent), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    content: '';
  }

  .technology-card strong {
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1;
    letter-spacing: -0.03em;
    text-align: center;
    transition: color 0.3s ease;
  }

  .practice-panel {
    display: grid;
    grid-template-columns: minmax(260px, 0.42fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 2.5rem);
    margin-top: clamp(2rem, 5vw, 3rem);
    align-items: start;
  }

  .practice-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .practice-card {
    min-height: 220px;
    padding: clamp(1rem, 2.5vw, 1.35rem);
    background:
      linear-gradient(145deg, rgba(16, 24, 39, 0.9), rgba(8, 13, 22, 0.76));
  }

  .practice-card > span {
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 800;
  }

  .practice-card h4 {
    margin: 2.25rem 0 0.75rem;
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
  }

  .practice-card p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .section-heading-row {
    display: grid;
    grid-template-columns: 1fr 0.7fr;
    gap: 2rem;
    align-items: end;
  }

  .section-heading-row > p {
    line-height: 1.75;
    font-size: 1.1rem;
  }

  .experience-list {
    display: grid;
    margin-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .experience-item {
    display: grid;
    grid-template-columns: minmax(220px, 300px) 1fr;
    gap: clamp(2rem, 5vw, 3.5rem);
    padding-block: 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .experience-left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-content: start;
  }

  .company-logo-wrap {
    display: inline-flex;
    align-self: start;
    margin-bottom: 0.6rem;
  }

  .company-logo {
    display: block;
    height: 1.75rem;
    width: auto;
    max-width: 140px;
    object-fit: contain;
  }

  .experience-period {
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .experience-role {
    margin: 0;
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .experience-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.85rem;
  }

  .stack-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.18rem 0;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .stack-pill img {
    width: 0.85rem;
    height: 0.85rem;
    flex-shrink: 0;
  }

  .experience-right p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .youtube-shell {
    position: relative;
    overflow: hidden;
    padding: clamp(1.25rem, 4vw, 2rem);
    background:
      radial-gradient(circle at 14% 12%, rgba(255, 0, 0, 0.2), transparent 18rem),
      radial-gradient(circle at 86% 0%, rgba(52, 211, 153, 0.16), transparent 20rem),
      linear-gradient(145deg, rgba(16, 24, 39, 0.96), rgba(8, 13, 22, 0.86));
  }

  .youtube-shell::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: '';
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: linear-gradient(135deg, black, transparent 72%);
  }

  .youtube-hero,
  .youtube-pillar-row,
  .featured-video-grid {
    position: relative;
    z-index: 1;
  }

  .youtube-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: stretch;
  }

  .youtube-copy {
    max-width: 850px;
  }

  .youtube-copy p:not(.eyebrow) {
    max-width: 760px;
    color: var(--color-text-muted);
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    line-height: 1.8;
  }

  .youtube-copy strong {
    color: var(--color-text);
  }

  .youtube-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .youtube-proof {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: clamp(1rem, 3vw, 1.35rem);
    background: rgba(255, 255, 255, 0.045);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .youtube-logo {
    display: grid;
    width: 4.7rem;
    height: 4.7rem;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 1.4rem;
    background:
      radial-gradient(circle at 50% 45%, rgba(255, 255, 255, 0.18), transparent 54%),
      rgba(255, 0, 0, 0.92);
    box-shadow: 0 20px 46px rgba(255, 0, 0, 0.2);
  }

  .youtube-logo svg {
    width: 2.4rem;
    fill: var(--color-text);
  }

  .youtube-logo svg path:last-child {
    fill: rgba(8, 13, 22, 0.96);
  }

  .youtube-proof-label {
    max-width: 14rem;
    margin: clamp(1.5rem, 5vw, 3.5rem) 0 1rem;
    font-size: clamp(1.55rem, 4vw, 2.2rem);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -0.06em;
  }

  .youtube-stat-grid {
    display: grid;
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius-lg) - 0.35rem);
    background: var(--color-border);
  }

  .youtube-stat-grid article {
    padding: 1rem;
    background: rgba(8, 13, 22, 0.68);
  }

  .youtube-stat-grid strong {
    display: block;
    color: var(--color-text);
    font-size: clamp(1.65rem, 4vw, 2.45rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .youtube-stat-grid span {
    display: block;
    margin-top: 0.35rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.35;
  }

  .youtube-pillar-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: clamp(1.5rem, 4vw, 2rem);
  }

  .youtube-pillar-row span {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    padding: 0.52rem 0.78rem;
    background: rgba(255, 255, 255, 0.045);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .featured-video-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    margin-top: clamp(1rem, 3vw, 1.35rem);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius-lg) - 0.25rem);
    background: var(--color-border);
  }

  .featured-video-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 20rem;
    padding: clamp(1rem, 2.5vw, 1.35rem);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), transparent 50%),
      rgba(13, 19, 34, 0.94);
  }

  .featured-video-card::before {
    position: absolute;
    inset: auto 1rem 0 1rem;
    height: 2px;
    background: linear-gradient(90deg, rgba(255, 0, 0, 0.85), rgba(52, 211, 153, 0.45), transparent);
    content: '';
  }

  .featured-video-card > span,
  .featured-video-card > p:first-of-type {
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .featured-video-card > p:first-of-type {
    margin: 0.5rem 0 0;
    color: rgba(248, 199, 126, 0.9);
  }

  .featured-video-card h3 {
    margin: clamp(2.25rem, 5vw, 3.4rem) 0 0.75rem;
    font-size: clamp(1.25rem, 2.4vw, 1.65rem);
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .featured-video-card p:last-of-type {
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .featured-video-card a {
    display: inline-flex;
    align-self: flex-start;
    margin-top: auto;
    color: var(--color-accent);
    font-weight: 800;
  }

  .book-shell {
    display: grid;
    grid-template-columns: minmax(260px, 0.42fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 3.5rem);
    align-items: stretch;
    overflow: hidden;
    padding: clamp(1.25rem, 4vw, 2.5rem);
    background:
      radial-gradient(circle at 18% 18%, rgba(248, 199, 126, 0.2), transparent 18rem),
      linear-gradient(145deg, rgba(17, 24, 39, 0.95), rgba(8, 13, 22, 0.86));
  }

  .book-visual {
    display: grid;
    min-height: 100%;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: calc(var(--radius-lg) - 0.35rem);
    padding: clamp(1.25rem, 4vw, 2.25rem);
    background:
      linear-gradient(135deg, rgba(248, 199, 126, 0.12), transparent 46%),
      rgba(255, 255, 255, 0.04);
  }

  .book-cover {
    display: block;
    width: min(100%, 18.5rem);
    height: auto;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 0.8rem;
    box-shadow: 24px 28px 64px rgba(0, 0, 0, 0.4);
  }

  .book-copy p:not(.eyebrow) {
    max-width: 760px;
    color: var(--color-text-muted);
    font-size: clamp(1.02rem, 2vw, 1.16rem);
    line-height: 1.8;
  }

  .book-copy {
    align-self: center;
    padding-block: clamp(0.5rem, 2vw, 1rem);
  }

  .book-copy strong {
    color: var(--color-text);
  }

  .book-stat-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    margin-top: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius-lg) - 0.35rem);
    background: var(--color-border);
  }

  .book-stat-grid article {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    text-align: center;
    background: rgba(8, 13, 22, 0.68);
  }

  .book-stat-grid strong {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3em;
    color: var(--color-text);
    font-size: clamp(1.35rem, 3vw, 2rem);
    line-height: 1;
    letter-spacing: -0.055em;
  }

  .book-stat-grid .star-row {
    display: flex;
    justify-content: center;
    gap: 0.15em;
    min-height: 1rem;
    margin-top: 0.5rem;
    font-size: 1rem;
    color: var(--color-accent);
  }

  .book-stat-grid .stat-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }


  .book-stat-grid span {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.35;
  }

  .book-highlight-list {
    display: grid;
    gap: 0.65rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .book-highlight-list li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  .book-highlight-list li::before {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--color-primary);
    content: '';
  }

  .book-actions {
    margin-top: 1.5rem;
  }

  @media (max-width: 980px) {
    .hero,
    .profile-shell,
    .profile-proof,
    .stack-heading-row,
    .practice-panel,
    .section-heading-row,
    .youtube-hero,
    .book-shell,
    .experience-item {
      grid-template-columns: 1fr;
    }

    .technology-grid,
    .featured-video-grid,
    .book-stat-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .book-stat-grid article {
      text-align: center;
    }

    .book-stat-grid strong {
      justify-content: center;
    }


    .book-stat-grid article:last-child {
      grid-column: 1 / -1;
      max-width: 50%;
      margin-inline: auto;
    }

    .hero::before {
      inset: 2% -18% 46% -18%;
    }

    .hero::after {
      inset: 8% -8% 52% -8%;
    }

    .hero {
      align-items: start;
      justify-items: center;
      min-height: auto;
    }

    .hero-statement {
      width: 100%;
      max-width: 760px;
      justify-self: center;
    }

    .hero-title {
      font-size: clamp(4rem, 11.8vw, 6.6rem);
    }

    .hero-profile {
      width: 100%;
      max-width: 520px;
